# Frontend Environment Variables
# Скопируйте этот файл в .env и заполните значения

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# API_BASE_URL не требуется - используется proxy из vite.config.js
# Запросы к API делаются на относительные пути: /api/...
VITE_WS_BASE_URL=ws://localhost:5000

# -----------------------------------------------------------------------------
# Third-party API Keys
# -----------------------------------------------------------------------------
VITE_MAPS_API_KEY=
VITE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
VITE_ENABLE_DEBUG_MODE=false
VITE_MAINTENANCE_MODE=false

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
VITE_APP_NAME=Бьюти Окна
VITE_ITEMS_PER_PAGE=20
VITE_API_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Development Configuration
# -----------------------------------------------------------------------------
# Порт для dev-сервера (по умолчанию 5173)
VITE_DEV_PORT=5173

# Открывать браузер при запуске (по умолчанию true)
VITE_OPEN_BROWSER=true

# URL прокси для API в dev-режиме (по умолчанию http://localhost:5000)
VITE_API_PROXY_TARGET=http://localhost:5000

# Анализ бандла: установить true для запуска visualizer
ANALYZE=false